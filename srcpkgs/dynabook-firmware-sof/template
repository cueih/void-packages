# Template file for 'sof-firmware'
pkgname=dynabook-firmware-sof
version=2025.12.2
revision=1
archs="x86_64*"
#hostmakedepends="rsync"
depends="alsa-ucm-conf"
short_desc="dynabook - sof firmware for audio (with dmic)"
maintainer="hieuc"
license="BSD-3-Clause"
homepage="https://thesofproject.github.io/latest/index.html"
distfiles="https://github.com/thesofproject/sof-bin/releases/download/v${version}/sof-bin-${version}.tar.gz"
checksum=533f63e3a6d94c09ce05a782657b675fa683ff20787c0979226cf563ec79f517
conflicts=sof-firmware

do_install() {
    # Create target dirs in DESTDIR
    vmkdir usr/lib/firmware/intel/sof
    vmkdir usr/lib/firmware/intel/sof/intel-signed
    vmkdir usr/lib/firmware/intel/sof-tplg

    # 1) Install topology file
    vinstall sof-tplg/sof-hda-generic-2ch.tplg 644 \
        usr/lib/firmware/intel/sof-tplg

    # 2) Install the real signed firmware file
    vinstall sof/intel-signed/sof-tgl.ri 644 \
        usr/lib/firmware/intel/sof/intel-signed

    # 3) Create the symlink that SOF actually loads
    ln -s intel-signed/sof-tgl.ri \
        "${DESTDIR}/usr/lib/firmware/intel/sof/sof-tgl.ri"

    # vlicense LICENCE.NXP
}
